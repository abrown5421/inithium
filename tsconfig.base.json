{
  "compilerOptions": {
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "target": "es2022",
    "skipLibCheck": true,
    "strict": true,
    "customConditions": ["@inithium/source"],
    "paths": {
      "@inithium/api-core": ["./packages/api-core/src/index.ts"],
      "@inithium/api-collections": ["./packages/api-collections/src/index.ts"],
      "@inithium/types": ["./packages/types/src/index.ts"],
      "@inithium/utils": ["./packages/utils/src/index.ts"],
      "@inithium/validators": ["./packages/validators/src/index.ts"]
    }
  }
}