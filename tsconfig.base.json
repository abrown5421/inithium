{
  "compilerOptions": {
    "paths": {
      "@inithium/*": ["./packages/*/src/index.ts"]
    },
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "target": "es2022",
    "skipLibCheck": true,
    "strict": true,
    "customConditions": ["@inithium/source"]
  }
}