{
  "name": "@inithium/ui",
  "version": "0.0.1",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "@inithium/source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./fonts": {
      "@inithium/source": "./src/lib/theme/fonts.css",
      "import": "./dist/fonts.css",
      "default": "./dist/fonts.css"
    }
  },
  "dependencies": {
    "@headlessui/react": "^2.2.0",
    "@inithium/utils": "workspace:*",
    "tslib": "^2.3.0"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  }
}
