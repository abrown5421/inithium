{
  "name": "@inithium/api-core",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "@inithium/source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./middleware": {
      "@inithium/source": "./src/lib/middleware/index.ts",
      "types": "./dist/lib/middleware/index.d.ts",
      "import": "./dist/lib/middleware/index.js",
      "default": "./dist/lib/middleware/index.js"
    }
  },
  "dependencies": {
    "@inithium/types": "workspace:*",
    "tslib": "^2.3.0",
    "mongoose": "^9.4.1",
    "express": "^4.21.2"
  }
}
