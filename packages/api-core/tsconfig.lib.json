{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "paths": {
      "*": ["./*"],
      "@inithium/types": ["../types/src/index.ts"]
    },
    "outDir": "dist",
    "rootDir": "src",
    "tsBuildInfoFile": "dist/tsconfig.lib.tsbuildinfo",
    "types": ["node"]
  },
  "include": ["src/**/*.ts"],
  "exclude": ["src/**/*.spec.ts", "src/**/*.test.ts"],
  "references": [
    {
      "path": "../types/tsconfig.lib.json"
    }
  ]
}
