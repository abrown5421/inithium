{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./out-tsc/jest",
    "types": ["jest", "node"],
    "forceConsistentCasingInFileNames": true,
    "paths": {
      "@inithium/types": ["../../packages/types/src/index.ts"],
      "@inithium/api-core": ["../../packages/api-core/src/index.ts"],
      "@inithium/api-collections": ["../../packages/api-collections/src/index.ts"]
    }
  },
  "include": [
    "jest.config.ts",
    "jest.config.cts",
    "src/**/*.test.ts",
    "src/**/*.spec.ts",
    "src/**/*.d.ts"
  ],
  "references": [
    {
      "path": "./tsconfig.app.json"
    }
  ]
}
